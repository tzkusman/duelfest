# Supabase project credentials (https://supabase.com/dashboard)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: required for admin operations (never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=

# Public app URL (no trailing slash) — used in share links, magic-link redirects
# NEXT_PUBLIC_APP_URL=

# Optional: payments (Phase 2)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx
