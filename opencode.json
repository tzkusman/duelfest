{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "go": {
      "disabled": false,
      "command": "gopls"
    },
    "typescript": {
      "disabled": false,
      "command": "typescript-language-server",
      "args": ["--stdio"]
    },
    "eslint": {
      "disabled": false,
      "command": "eslint",
      "args": ["--stdio"]
    },
    "tailwindcss": {
      "disabled": false,
      "command": "tailwindcss-language-server",
      "args": ["--stdio"]
    }
  },
  "mcp": {
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true
    }
  }
}
